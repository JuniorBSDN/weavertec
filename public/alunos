   <script>

              // 2. FUNÇÃO UNIFICADA PARA DROPDOWNS DESKTOP
        function configurarDropdownDesktop(btnId, menuId, chevronId) {
            const btn = document.getElementById(btnId);
            const menu = document.getElementById(menuId);

            if (!btn || !menu) return;

            btn.addEventListener('click', (e) => {
                e.stopPropagation();

                // Fecha o outro menu que estiver aberto
                fecharTodosDropdowns(menuId);

                const abrindo = menu.classList.contains('hidden');
                const chevron = document.getElementById(chevronId);

                if (abrindo) {
                    btn.setAttribute('aria-expanded', 'true');
                    menu.classList.remove('hidden');
                    setTimeout(() => {
                        menu.classList.remove('opacity-0', 'scale-95');
                        menu.classList.add('opacity-100', 'scale-100');
                        if (chevron) chevron.classList.add('rotate-180');
                    }, 10);
                } else {
                    btn.setAttribute('aria-expanded', 'false');
                    menu.classList.remove('opacity-100', 'scale-100');
                    menu.classList.add('opacity-0', 'scale-95');
                    if (chevron) chevron.classList.remove('rotate-180');
                    setTimeout(() => { menu.classList.add('hidden'); }, 200);
                }
            });
        }

        function fecharTodosDropdowns(ignorarMenuId = null) {
            const configs = [
                { btn: 'tecnicosDropdownBtn', menu: 'tecnicosDropdownMenu', chev: 'tecnicosChevron' },
                { btn: 'profDropdownBtn', menu: 'profDropdownMenu', chev: 'profChevron' }
            ];
            configs.forEach(item => {
                if (item.menu !== ignorarMenuId) {
                    const btn = document.getElementById(item.btn);
                    const menu = document.getElementById(item.menu);
                    const chev = document.getElementById(item.chev);
                    if (menu && !menu.classList.contains('hidden')) {
                        btn.setAttribute('aria-expanded', 'false');
                        menu.classList.remove('opacity-100', 'scale-100');
                        menu.classList.add('opacity-0', 'scale-95');
                        if (chev) chev.classList.remove('rotate-180');
                        setTimeout(() => { menu.classList.add('hidden'); }, 200);
                    }
                }
            });
        }

        configurarDropdownDesktop('tecnicosDropdownBtn', 'tecnicosDropdownMenu', 'tecnicosChevron');
        configurarDropdownDesktop('profDropdownBtn', 'profDropdownMenu', 'profChevron');

        // Fecha menus se clicar fora de qualquer elemento do cabeçalho
        document.addEventListener('click', () => fecharTodosDropdowns());


        // 3. MENU MOBILE HAMBURGUER (Toggle Geral)
        const mobileMenuButton = document.getElementById('mobileMenuButton');
        const mobileMenu = document.getElementById('mobile-menu');
        const iconMenu = document.getElementById('iconMenu');
        const iconX = document.getElementById('iconX');

        if (mobileMenuButton && mobileMenu) {
            mobileMenuButton.addEventListener('click', () => {
                const isHidden = mobileMenu.classList.contains('hidden');
                if (isHidden) {
                    mobileMenu.classList.remove('hidden');
                    mobileMenuButton.setAttribute('aria-expanded', 'true');
                    if(iconMenu) iconMenu.classList.add('hidden');
                    if(iconX) iconX.classList.remove('hidden');
                } else {
                    mobileMenu.classList.add('hidden');
                    mobileMenuButton.setAttribute('aria-expanded', 'false');
                    if(iconMenu) iconMenu.classList.remove('hidden');
                    if(iconX) iconX.classList.add('hidden');
                }
            });
        }

        // 4. SUBMENUS SANFONA DO CELULAR (Mobile Accordion)
        function configurarSanfonaMobile(btnId, submenuId, chevronId) {
            const btn = document.getElementById(btnId);
            const sub = document.getElementById(submenuId);
            if (btn && sub) {
                btn.addEventListener('click', () => {
                    const escondido = sub.classList.contains('hidden');
                    const chev = document.getElementById(chevronId);
                    if (escondido) {
                        sub.classList.remove('hidden');
                        if (chev) chev.classList.add('rotate-180');
                    } else {
                        sub.classList.add('hidden');
                        if (chev) chev.classList.remove('rotate-180');
                    }
                });
            }
        }
        configurarSanfonaMobile('mobileTecnicosBtn', 'mobileTecnicosSubmenu', 'mobileTecnicosChevron');
        configurarSanfonaMobile('mobileProfBtn', 'mobileProfSubmenu', 'mobileProfChevron');
      // Inicialização global de ícones
      lucide.createIcons();

      const modalCurso = document.getElementById('modal-sala-aula');

      // Alternância Dinâmica das Seções do Menu Lateral
      function navegarPara(idModulo) {
         // Oculta todas as seções de conteúdo
         document.querySelectorAll('.modulo-content').forEach(secao => {
            secao.classList.add('hidden');
         });

         // Remove estilos ativos de todos os botões do menu
         document.querySelectorAll('.menu-btn').forEach(btn => {
            btn.classList.remove('bg-slate-800', 'text-white');
            btn.classList.add('hover:bg-slate-800', 'hover:text-white');
         });

         // Exibe a seção clicada
         document.getElementById(idModulo).classList.remove('hidden');

         // Aplica estilo ativo ao botão clicado
         const btnAtivo = document.getElementById(`btn-${idModulo}`);
         if (btnAtivo) {
            btnAtivo.classList.add('bg-slate-800', 'text-white');
            btnAtivo.classList.remove('hover:bg-slate-800', 'hover:text-white');
         }
      }

      // Abre a plataforma de vídeos 100%
      function abrirCurso() {
         modalCurso.style.display = 'flex';
         modalCurso.showModal();
      }

      // Fecha a plataforma de vídeos 100%
      function fecharCurso() {
         modalCurso.close();
         modalCurso.style.display = 'none';
      }
